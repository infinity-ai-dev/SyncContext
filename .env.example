# ============================================
# SyncContext - Environment Configuration
# ============================================

# Required: Token do projeto (compartilhado pelo time)
# Gere com: openssl rand -hex 32
SYNCCONTEXT_PROJECT_TOKEN=your-project-token-here

# Admin token (opcional, para criar/listar projetos)
# SYNCCONTEXT_ADMIN_TOKEN=

# ── Embedding Provider ──────────────────────────────────
# Auto-detectado pela credencial preenchida:
#   - GEMINI_API_KEY preenchida → usa Gemini (grátis)
#   - OPENAI_API_KEY preenchida → usa OpenAI
#   - OLLAMA_BASE_URL preenchida → usa Ollama (offline)
#
# Ou force manualmente: gemini, openai, ollama
# SYNCCONTEXT_EMBEDDING_PROVIDER=auto

# Gemini (default, grátis - https://aistudio.google.com/apikey)
SYNCCONTEXT_GEMINI_API_KEY=your-gemini-api-key

# OpenAI (opcional)
# SYNCCONTEXT_OPENAI_API_KEY=

# Ollama (opcional, offline)
# SYNCCONTEXT_OLLAMA_BASE_URL=http://host.docker.internal:11434
# SYNCCONTEXT_OLLAMA_MODEL=nomic-embed-text

# ── Database ────────────────────────────────────────────
POSTGRES_PASSWORD=synccontext
# POSTGRES_PORT=5432

# Fallback order:
#   1. SYNCCONTEXT_LOCAL_DATABASE_URL (Docker network / self-hosted Postgres)
#   2. SYNCCONTEXT_DATABASE_URL (remote runtime URL, e.g. Supabase pooler)
#   3. SYNCCONTEXT_DIRECT_URL (direct Postgres, used for migrations/DDL when runtime uses a pooler)
# SYNCCONTEXT_LOCAL_DATABASE_URL=postgresql://postgres:password@postgres:5432/synccontext
# SYNCCONTEXT_DATABASE_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
# SYNCCONTEXT_DIRECT_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ── Vector Store ────────────────────────────────────────
# pgvector (default) ou redis
# SYNCCONTEXT_VECTOR_STORE=pgvector
# REDIS_PORT=6379

# ── Server ──────────────────────────────────────────────
SYNCCONTEXT_TRANSPORT=stdio
SYNCCONTEXT_LOG_LEVEL=INFO
