# ============================================
# SyncContext - Environment Configuration
# ============================================

# Required: Project token (shared secret for team access)
# Generate one with: openssl rand -hex 32
SYNCCONTEXT_PROJECT_TOKEN=your-project-token-here

# Image version (default: latest)
# SYNCCONTEXT_VERSION=0.1.0

# ── Vector Store ────────────────────────────────────────
# Backend: "pgvector" (default) or "redis"
# If using redis, start with: docker compose --profile redis up -d
SYNCCONTEXT_VECTOR_STORE=pgvector

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_PASSWORD=synccontext
# POSTGRES_PORT=5432

# ── Redis (only if VECTOR_STORE=redis) ──────────────────
# REDIS_PORT=6379

# ── Embedding Provider ──────────────────────────────────
# Options: "gemini" (default, free), "openai", "ollama"
SYNCCONTEXT_EMBEDDING_PROVIDER=gemini

# Gemini (default, free tier - https://aistudio.google.com/apikey)
SYNCCONTEXT_GEMINI_API_KEY=your-gemini-api-key

# OpenAI (optional)
# SYNCCONTEXT_OPENAI_API_KEY=

# Ollama (optional, offline - host.docker.internal resolves to host machine)
# SYNCCONTEXT_OLLAMA_BASE_URL=http://host.docker.internal:11434
# SYNCCONTEXT_OLLAMA_MODEL=nomic-embed-text

# ── Server ──────────────────────────────────────────────
SYNCCONTEXT_TRANSPORT=stdio
SYNCCONTEXT_LOG_LEVEL=INFO
