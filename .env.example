# ============================================
# SyncContext - Environment Configuration
# ============================================

# Required: Project token (shared secret for team access)
SYNCCONTEXT_PROJECT_TOKEN=your-project-token-here

# PostgreSQL connection (always required for metadata storage)
SYNCCONTEXT_DATABASE_URL=postgresql://synccontext:password@localhost:5432/synccontext

# Vector Store backend: "pgvector" or "redis"
SYNCCONTEXT_VECTOR_STORE=pgvector

# Redis (only if VECTOR_STORE=redis)
SYNCCONTEXT_REDIS_URL=redis://localhost:6379/0

# Embedding Provider: "gemini" (default), "openai", "ollama"
SYNCCONTEXT_EMBEDDING_PROVIDER=gemini

# Gemini (default, free tier)
SYNCCONTEXT_GEMINI_API_KEY=your-gemini-api-key

# OpenAI (optional, cloud)
SYNCCONTEXT_OPENAI_API_KEY=

# Ollama (optional, offline)
SYNCCONTEXT_OLLAMA_BASE_URL=http://localhost:11434
SYNCCONTEXT_OLLAMA_MODEL=nomic-embed-text

# Server transport: "stdio" (default), "sse", "streamable-http"
SYNCCONTEXT_TRANSPORT=stdio
SYNCCONTEXT_LOG_LEVEL=INFO
